{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["HOST", "TRUST_PROXY", "QUAD_TENANT_HOSTS"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["API_PROXY_ORIGIN"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build", "db:generate"]
    },
    "db:generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["src/generated/**"]
    },
    "test": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build", "db:generate"],
      "passThroughEnv": ["DATABASE_URL", "REDIS_URL"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["^build", "db:generate"],
      "cache": false
    },
    "format": {
      "cache": false
    },
    "check": {
      "dependsOn": ["lint", "typecheck", "test", "build"]
    }
  }
}
