# Quad — example environment (SCAFFOLDING ONLY)
# ----------------------------------------------------------------------------
# Copy to .env for LOCAL development and fill in. NEVER commit real secrets.
# Production secrets live in the secrets manager (see docs/DEPLOYMENT.md §10),
# not in this repo. All values below are EXAMPLES/placeholders only.
# Per-environment separation: local / staging / production each have their own.
# Versions/providers are governed by docs/TECH_BASELINE.md & ADR-0010.
# ----------------------------------------------------------------------------

# --- Runtime environment ---
NODE_ENV=development                       # development | test | production

# --- App URLs / tenant host examples ---
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
API_PROXY_ORIGIN=                         # Optional web-tier same-origin /api proxy target, e.g. https://quad-canvas-api-test.vercel.app
# Tenant resolution is host/subdomain based (no default tenant). Example tenant #1:
#   rutgers.localhost (local) → ten_rutgers   (Rutgers Quad = tenant #1, config only)
TENANT_EXAMPLE_HOST=rutgers.localhost

# --- Database (PostgreSQL) — placeholder ---
DATABASE_URL=postgresql://quad:quad@localhost:5432/quad
# DATABASE_REPLICA_URL=postgresql://quad:quad@localhost:5432/quad   # optional read replica

# --- Redis / Valkey — placeholder ---
REDIS_URL=redis://localhost:6379

# --- Auth / session secrets — placeholders (generate per environment) ---
AUTH_SECRET=__change_me__                  # @auth/core / session signing secret
SESSION_COOKIE_NAME=quad_session           # httpOnly + Secure + SameSite, host-only per tenant
CSRF_SECRET=__change_me__                   # exact CSRF scheme: ADR-0006

# --- Email provider (verification) — placeholders ---
EMAIL_PROVIDER=__provider__
EMAIL_API_KEY=__change_me__
EMAIL_FROM=no-reply@example.edu

# --- Object storage (archives / replay / final images) — placeholders ---
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=quad-archives
OBJECT_STORAGE_ACCESS_KEY=__change_me__
OBJECT_STORAGE_SECRET_KEY=__change_me__

# --- Observability — placeholders (DC5 only; never DC3 in telemetry) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

# --- Feature flags / launch flags (per-tenant flags live in @quad/config) ---
FLAG_READONLY_VIEWING=false                # P-Q-2
FLAG_ARCHIVE_VISIBILITY=public             # public | members

# --- Security / origin allowlist — placeholders ---
ALLOWED_ORIGINS=http://localhost:3000      # WS handshake + CORS origin allowlist
QUAD_TENANT_HOSTS=                         # Optional exact host aliases: rutgers=web-test.vercel.app,api-test.vercel.app

# --- Tenant config hints ---
# Tenant settings (domains, palette, theme, auth provider) live in @quad/config,
# NOT here. Rutgers may appear only as tenant #1 example host/comment.
