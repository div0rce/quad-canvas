// @quad/db — Prisma schema. Foundation tables + the pixel-placement event log/projection.
// `pixel_events` is the append-only source of truth; `pixels` is the derived current-canvas
// projection (rebuildable from the log). Append + projection + idempotency commit atomically
// (see docs/EVENT_SOURCING.md §9, docs/DATABASE.md). Replay/moderation/stat tables land later.
// Tenant isolation first; tenant-scoped uniqueness; NO default tenant. Events are never mutated.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  // Prisma 7: no `url` here. The runtime connection comes from the driver adapter
  // (PrismaPg, see src/client.ts); the CLI/Migrate URL lives in prisma.config.ts.
  provider = "postgresql"
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  publicTitle String
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships       Membership[]
  canvases          Canvas[]
  pixelEvents       PixelEvent[]
  pixels            Pixel[]
  moderationActions ModerationAction[]
  reports           Report[]
  friendships       Friendship[]
  guilds            Guild[]
  guildMemberships  GuildMembership[]
}

model User {
  // DC3 internal identity. `email` is PRIVATE — never serialized into a public DTO/log.
  id           String   @id @default(cuid())
  email        String   @unique
  // DC2 public-facing fields (nullable until set). Tenant-scoped handle uniqueness is
  // intentionally NOT enforced yet — handle-vs-membership placement is unresolved (see T6 notes).
  publicHandle String?
  displayName  String?
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships          Membership[]
  pixelEvents          PixelEvent[]
  pixels               Pixel[]
  moderationActions    ModerationAction[]
  reports              Report[]
  friendshipsRequested Friendship[]       @relation("friendshipRequester")
  friendshipsReceived  Friendship[]       @relation("friendshipAddressee")
  guildsCreated        Guild[]            @relation("guildCreator")
  guildMemberships     GuildMembership[]
}

model Membership {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tenant-scoped uniqueness: a user has at most one membership per tenant.
  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Canvas {
  id         String    @id @default(cuid())
  tenantId   String
  termLabel  String
  status     String
  width      Int
  height     Int
  startsAt   DateTime?
  endsAt     DateTime?
  frozenAt   DateTime?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pixelEvents PixelEvent[]
  pixels      Pixel[]
  reports     Report[]

  // One canvas per term per tenant (tenant-scoped).
  @@unique([tenantId, termLabel])
  @@index([tenantId])
}

// Append-only event log — the source of truth (DC1, tenant-scoped). Never updated or deleted.
// `seq` is the authoritative per-canvas order assigned at append (NOT a timestamp).
model PixelEvent {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  canvasId       String   @map("canvas_id")
  actorUserId    String   @map("user_id")
  type           String
  seq            Int
  // Coordinates exist for pixel events; lifecycle events share the ordered canvas stream and use
  // a typed JSON payload instead.
  x              Int?
  y              Int?
  prevColor      Int?     @map("prev_color")
  newColor       Int?     @map("new_color")
  payload        Json?
  idempotencyKey String   @map("idempotency_key")
  schemaVersion  Int      @default(1) @map("schema_version")
  createdAt      DateTime @default(now()) @map("created_at")

  // Restrict (not Cascade): the append-only log is permanent truth — a tenant/canvas/user with
  // events cannot be hard-deleted out from under it (PRIN-PERMANENCE, ES-INV-2).
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  canvas          Canvas  @relation(fields: [canvasId], references: [id], onDelete: Restrict)
  actor           User    @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  latestForPixels Pixel[]

  @@unique([canvasId, seq]) // per-canvas authoritative order
  @@unique([tenantId, idempotencyKey]) // duplicate-safe, tenant-scoped
  @@index([canvasId, actorUserId]) // per-user last placement (cooldown derivation)
  @@index([canvasId, x, y, seq]) // per-cell history (ordered)
  @@index([tenantId])
  @@index([tenantId, actorUserId]) // per-user placement count (profiles)
  @@index([canvasId, type, createdAt]) // recent-placement load count (dynamic cooldown)
  @@map("pixel_events")
}

// Current-canvas projection (derived from pixel_events; rebuildable). One row per cell.
model Pixel {
  tenantId    String   @map("tenant_id")
  canvasId    String   @map("canvas_id")
  x           Int
  y           Int
  color       Int
  ownerUserId String   @map("owner_user_id")
  lastEventId String   @map("last_event_id")
  seq         Int
  placedAt    DateTime @map("placed_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  canvas    Canvas     @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  owner     User       @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  lastEvent PixelEvent @relation(fields: [lastEventId], references: [id], onDelete: Restrict)

  @@id([canvasId, x, y]) // exactly one row per (canvas, x, y)
  @@index([tenantId])
  @@map("pixels")
}

// Append-only audit of moderation/admin actions (DC4). Never updated or deleted — every action is
// a permanent, attributed record (actor, action, target, reason, time). FK-RESTRICTed like the log.
model ModerationAction {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  actorUserId    String   @map("actor_user_id")
  actionType     String   @map("action_type")
  targetRef      String   @map("target_ref")
  reason         String?
  relatedEventId String?  @map("related_event_id")
  idempotencyKey String?  @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actor  User   @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@unique([tenantId, idempotencyKey]) // idempotent rollbacks (tenant-scoped; nulls are distinct)
  @@index([tenantId, createdAt])
  @@map("moderation_actions")
}

// User reports feeding the moderation queue (DC4 truth). Status transitions open → resolved/dismissed.
model Report {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  canvasId       String?  @map("canvas_id")
  reporterUserId String   @map("reporter_user_id")
  targetRef      String   @map("target_ref")
  reason         String
  status         String   @default("open")
  idempotencyKey String?  @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  reporter User    @relation(fields: [reporterUserId], references: [id], onDelete: Restrict)
  canvas   Canvas? @relation(fields: [canvasId], references: [id], onDelete: SetNull)

  @@unique([tenantId, idempotencyKey]) // duplicate-safe retries (tenant-scoped; nulls are distinct)
  @@index([tenantId, status, createdAt])
  @@map("reports")
}

// Campus friend graph: request-based, tenant-scoped. A row is a directed request
// (requester -> addressee); `status` = pending | accepted. Both directions are read to
// resolve a user's confirmed friends. DC2 only — the graph never exposes any email.
model Friendship {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  requesterUserId String   @map("requester_user_id")
  addresseeUserId String   @map("addressee_user_id")
  status          String   @default("pending")
  idempotencyKey  String?  @map("idempotency_key")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requester User   @relation("friendshipRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  addressee User   @relation("friendshipAddressee", fields: [addresseeUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, requesterUserId, addresseeUserId])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, addresseeUserId, status])
  @@index([tenantId, requesterUserId, status])
  @@map("friendships")
}

// Guilds: social/identity grouping within a tenant. Purely cosmetic — a guild confers NO placement
// advantage (fairness invariant); it is a team badge + directory. A user may belong to several and
// mark one as their active guild (attribution).
model Guild {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  slug            String
  name            String
  description     String?
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User              @relation("guildCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  members   GuildMembership[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("guilds")
}

model GuildMembership {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  guildId   String   @map("guild_id")
  userId    String   @map("user_id")
  // At most one active guild per user per tenant (enforced in the repo on set-active).
  active    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guild  Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, guildId, userId])
  @@index([tenantId, userId])
  @@index([guildId])
  @@map("guild_memberships")
}
