# Local secrets and environment files. Configure real values in Vercel project env vars.
.env
.env.*
!.env.example
!.env.prod.example

# Dependency, build, and cache outputs are regenerated by Vercel.
node_modules/
**/node_modules/
.turbo/
**/.turbo/
.next/
**/.next/
dist/
**/dist/
build/
**/build/
out/
**/out/
*.tsbuildinfo

# Local agent/editor/runtime state.
.claude/
.DS_Store
.idea/
.vscode/*.local

# Test and diagnostics artifacts.
coverage/
playwright-report/
test-results/
*.log
logs/

# Container/local deployment metadata is not used by Vercel builds.
**/Dockerfile
docker-compose*.yml
deploy/
