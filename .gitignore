# Dependencies
node_modules/
.pnpm-store/

# Environment / secrets (keep example env files tracked)
.env
.env.*
!.env.example
!.env.prod.example

# Build / generated outputs
dist/
build/
.next/
out/
.turbo/
*.tsbuildinfo
# Prisma-generated client output (generated at implementation; path settled in DATABASE.md)
**/generated/

# Test / coverage
coverage/
.nyc_output/
playwright-report/
test-results/

# Logs
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# OS / editor junk
.DS_Store
Thumbs.db
.idea/
*.swp
# (VS Code settings intentionally allowed; ignore local-only overrides)
.vscode/*.local

# Local Claude Code state (worktrees, session data)
.claude/
