# Quad — production COMPOSE example env (docker-compose.prod.yml). Copy to `.env.prod` and set real
# values; never commit it. Distinct from `.env.example` (local dev) because the containerised API
# reaches the datastores by SERVICE NAME (postgres/redis), not localhost.

# --- Postgres (datastore) ---
POSTGRES_USER=quad
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=quad

# --- Application ---
# DATABASE_URL targets the `postgres` service and must match POSTGRES_USER/PASSWORD/DB above.
DATABASE_URL=postgresql://quad:change-me-in-production@postgres:5432/quad
REDIS_URL=redis://redis:6379
# Behind a load balancer / reverse proxy, trust X-Forwarded-* to resolve the real client IP.
TRUST_PROXY=true
# Load-based cooldown (the Redis fast-path is active because REDIS_URL is set).
QUAD_DYNAMIC_COOLDOWN=1
# Host port the API is published on.
API_PORT=3000
# Host port the web UI is published on (direct/debug access).
WEB_PORT=8080
# Host port the edge proxy is published on — the single origin the browser uses (maps to :80 in prod).
EDGE_PORT=8088
